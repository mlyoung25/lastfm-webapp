# Get your keys at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_32_char_api_key
LASTFM_API_SECRET=your_32_char_api_secret

# Callback base URL you registered with Last.fm (no trailing slash).
# Local: http://localhost:3000
# Render: https://your-service-name.onrender.com
BASE_URL=http://localhost:3000

# Session secret (required in production; use a long random value)
SESSION_SECRET=change_me_to_random_string

# Set to production on Render
NODE_ENV=production
